{
	"name": "cloudflare-mcp-for-static-sites",
	"version": "1.0.0",
	"private": true,
	"description": "Publish your static site to AI assistants with a Cloudflare Worker that serves your content over MCP.",
	"license": "MIT",
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"format": "biome format --write src/",
		"lint:fix": "biome lint --fix src/",
		"start": "wrangler dev",
		"cf-typegen": "wrangler types",
		"type-check": "tsc --noEmit",
		"validate": "bun scripts/validate-index.ts"
	},
	"dependencies": {
		"agents": "^0.11.4",
		"fuse.js": "^7.3.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/node": "^25.6.0",
		"typescript": "5.9.3",
		"wrangler": "^4.84.0"
	}
}
